<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kalkulator Numerik</title>
</head>
<body class="bg-slate-900 text-slate-200 font-sans min-h-screen selection:bg-blue-500/30">

    <header class="bg-slate-950 border-b border-slate-800 shadow-xl py-6 px-4 md:px-8">
        <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
            <div class="flex items-center gap-3">
                <div class="p-3 bg-blue-600 rounded-xl shadow-lg">
                    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
                </div>
                <div>
                    <h1 class="text-2xl font-bold text-white tracking-tight">Kalkulator Numerik</h1>
                    <p class="text-sm text-slate-400">Penyelesaian Sistem Persamaan Lanjar (SPL)</p>
                </div>
            </div>
            <div class="text-right text-xs text-slate-400 bg-slate-900 p-3 rounded-lg border border-slate-800">
                <span class="font-semibold text-slate-300 block mb-1">Tim Pengembang (Teknik Informatika - UNPER)</span>
                Muhamad Gibran Aji Sutama &bull; Nasywa Aprisa Zustira &bull; Bimo Alviana Sopian
            </div>
        </div>
    </header>

    <main class="max-w-6xl mx-auto p-4 md:p-8 grid grid-cols-1 lg:grid-cols-12 gap-8">
        
        <div class="lg:col-span-4 space-y-6">
            <div class="bg-slate-800 rounded-2xl p-6 border border-slate-700 shadow-xl">
                <h2 class="text-lg font-semibold text-white mb-5">Parameter Kontrol</h2>
                
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-slate-400 mb-2">Metode Penyelesaian</label>
                        <select id="methodSelect" class="w-full bg-slate-900 border border-slate-600 rounded-xl py-3 px-4 text-white focus:outline-none focus:ring-2 focus:ring-blue-500" onchange="toggleIterationParams()">
                            <option value="balikan">Matriks Balikan (Invers)</option>
                            <option value="jacobi">Lelaran Jacobi</option>
                            <option value="gauss-seidel">Lelaran Gauss-Seidel</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-slate-400 mb-2">Dimensi Matriks (n x n)</label>
                        <input type="number" id="sizeInput" min="2" max="10" value="2" class="w-full bg-slate-900 border border-slate-600 rounded-xl py-2.5 px-4 text-white focus:outline-none focus:ring-2 focus:ring-blue-500" onchange="renderGrid()">
                    </div>

                    <div id="iterParams" class="hidden pt-4 border-t border-slate-700 space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-slate-400 mb-2">Toleransi Error (ε)</label>
                            <input type="number" id="tolInput" step="0.0001" value="0.01" class="w-full bg-slate-900 border border-slate-600 rounded-xl py-2.5 px-4 text-white focus:outline-none focus:ring-2 focus:ring-blue-500">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-400 mb-2">Maksimal Iterasi</label>
                            <input type="number" id="maxIterInput" value="100" class="w-full bg-slate-900 border border-slate-600 rounded-xl py-2.5 px-4 text-white focus:outline-none focus:ring-2 focus:ring-blue-500">
                        </div>
                    </div>
                </div>
                
                <div class="mt-8 pt-6 border-t border-slate-700 space-y-3">
                    <button onclick="calculate()" class="w-full bg-blue-600 hover:bg-blue-500 text-white font-semibold py-3 px-4 rounded-xl transition-all shadow-lg shadow-blue-500/20">
                        Hitung Solusi
                    </button>
                    <div class="grid grid-cols-2 gap-3">
                        <button onclick="resetData()" class="bg-slate-700 hover:bg-slate-600 text-slate-200 font-medium py-2 px-4 rounded-xl transition-all">
                            Reset
                        </button>
                        <button onclick="loadExample()" class="bg-emerald-600/20 text-emerald-400 hover:bg-emerald-600/30 border border-emerald-500/20 font-medium py-2 px-4 rounded-xl transition-all text-sm">
                            Contoh Soal
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="lg:col-span-8 space-y-6">
            <div class="bg-slate-800 rounded-2xl p-6 border border-slate-700 shadow-xl overflow-x-auto custom-scrollbar">
                <h2 class="text-lg font-semibold text-white mb-6">Sistem Persamaan Linier (SPL)</h2>
                <div class="flex gap-8 items-start min-w-max">
                    <div>
                        <div class="text-center text-sm font-medium text-slate-400 mb-3">Matriks Koefisien (A)</div>
                        <div class="bg-slate-900 p-4 rounded-xl border border-slate-700">
                            <div id="matrixGrid" class="grid gap-2"></div>
                        </div>
                    </div>
                    <div>
                        <div class="text-center text-sm font-medium text-slate-400 mb-3">Vektor (B)</div>
                        <div class="bg-slate-900 p-4 rounded-xl border border-slate-700">
                            <div id="vectorGrid" class="grid gap-2"></div>
                        </div>
                    </div>
                </div>

                <div id="guessContainer" class="hidden mt-8 pt-6 border-t border-slate-700">
                    <div class="text-sm font-medium text-slate-400 mb-3">Tebakan Awal (Initial Guess X₀)</div>
                    <div id="guessGrid" class="flex flex-wrap gap-2"></div>
                </div>
            </div>

            <div id="resultArea" class="hidden scroll-mt-8 space-y-6"></div>
        </div>
    </main>
